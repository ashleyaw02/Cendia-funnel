---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/cendia-blog-post.css';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const formattedDate = new Date(post.data.publishDate).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.publishDate.toISOString(),
  dateModified: post.data.publishDate.toISOString(),
  author: {
    '@type': 'Organization',
    name: 'Cendia Solutions',
    url: 'https://cendiasolutions.com',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Cendia Solutions',
    url: 'https://cendiasolutions.com',
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': `https://blog.cendiasolutions.com/blog/${post.data.slug}`,
  },
  articleSection: post.data.category,
  keywords: post.data.keywords.join(', '),
  about: post.data.primaryFramework,
};
---

<BaseLayout
  title={`${post.data.title} | Cendia Insights`}
  description={post.data.description}
  ogImage={post.data.ogImage}
>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />

  <article class="cendia-blog-article">
    <div class="post-meta">
      <span class="category">{post.data.category}</span>
      <span class="dot"></span>
      <span>{formattedDate}</span>
      <span class="dot"></span>
      <span>{post.data.readingTime} min read</span>
    </div>

    <Content />
  </article>
</BaseLayout>
