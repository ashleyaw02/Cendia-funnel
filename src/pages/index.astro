---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.publishDate).valueOf() - new Date(a.data.publishDate).valueOf()
);
---

<BaseLayout
  title="Cendia Insights — Operational Intelligence for Services Firms"
  description="Field notes from Cendia Solutions. Operational frameworks, hidden costs, and the structural causes of margin leakage in 30-100 person services firms."
>
  <section class="hero">
    <div class="container">
      <p class="eyebrow">Cendia Insights</p>
      <h1>Operational intelligence for <em>services firms</em>.</h1>
      <p class="lead">
        Field notes from Cendia Solutions. Diagnostic frameworks, hidden cost analysis, and the structural causes most firms can't see — written for founders and operators of 30-100 person businesses.
      </p>
    </div>
  </section>

  <div class="container">
    <hr class="section-divider" />
  </div>

  <section class="posts">
    <div class="container">
      <p class="eyebrow">Recent posts</p>

      {posts.length === 0 ? (
        <p>No posts yet. The blog launches soon.</p>
      ) : (
        <ul class="post-list">
          {posts.map((post) => (
            <li class="post-card">
              <a href={`/blog/${post.data.slug}`}>
                <span class="post-category">{post.data.category}</span>
                <h2>{post.data.title}</h2>
                <p class="post-description">{post.data.description}</p>
                <p class="post-meta-line">
                  {new Date(post.data.publishDate).toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric',
                  })} &middot; {post.data.readingTime} min read
                </p>
              </a>
            </li>
          ))}
        </ul>
      )}
    </div>
  </section>

  <style>
    .hero {
      padding: 80px 0 48px;
    }

    .hero h1 {
      max-width: 18ch;
    }

    .hero h1 em {
      font-style: italic;
      color: var(--gold-muted);
      font-family: var(--font-display);
    }

    .section-divider {
      border: none;
      width: 96px;
      height: 2px;
      background: var(--gold-muted);
      margin: 0 0 16px;
    }

    .posts {
      padding: 32px 0 96px;
    }

    .post-list {
      list-style: none;
      padding: 0;
      margin: 24px 0 0;
      display: grid;
      gap: 24px;
      grid-template-columns: 1fr;
    }

    @media (min-width: 768px) {
      .post-list {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    .post-card {
      background: var(--white);
      border: 1px solid var(--gray-light);
      transition: border-color 120ms ease;
    }

    .post-card:hover {
      border-color: var(--gold-muted);
    }

    .post-card a {
      display: block;
      padding: 24px;
      color: inherit;
      text-decoration: none;
    }

    .post-card .post-category {
      display: inline-block;
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 2.4px;
      text-transform: uppercase;
      color: var(--gold-muted);
      margin-bottom: 12px;
    }

    .post-card h2 {
      font-size: 24px;
      margin: 0 0 12px;
      line-height: 1.25;
      color: var(--navy-dark);
    }

    .post-card .post-description {
      color: var(--gray-dark);
      font-size: 15px;
      margin: 0 0 16px;
      line-height: 1.5;
    }

    .post-card .post-meta-line {
      font-size: 13px;
      color: var(--gray-warm);
      margin: 0;
    }
  </style>
</BaseLayout>
