---
export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Operational Intelligence Advisory for services firms. Cendia diagnoses operational leaks, designs interventions, and recovers margin in 30-90 days.',
  ogImage = '/og-default.png',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="twitter:card" content="summary_large_image" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body>
    <header class="site-header">
      <div class="container header-inner">
        <a href="/" class="wordmark-on-light" style="text-decoration: none;">
          <div class="wordmark">CENDIA SOLUTIONS</div>
          <div class="wordmark-subtitle">Operational Intelligence Advisory</div>
        </a>
        <nav class="site-nav">
          <a href="/">Insights</a>
          <a href="https://cendiasolutions.com">Main Site</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <div class="wordmark-on-dark">
          <div class="wordmark">CENDIA SOLUTIONS</div>
          <div class="wordmark-subtitle">Operational Intelligence Advisory</div>
        </div>
        <p class="footer-meta">
          &copy; 2026 Cendia Solutions. <a href="https://cendiasolutions.com">cendiasolutions.com</a> &middot; <a href="mailto:support@cendiasolutions.com">support@cendiasolutions.com</a>
        </p>
      </div>
    </footer>

    <style is:global>
      @import '/src/styles/cendia-brand.css';

      .container {
        max-width: 1100px;
        margin: 0 auto;
        padding: 0 24px;
      }

      .site-header {
        background: var(--white-warm);
        padding: 24px 0;
        border-bottom: 1px solid var(--gray-light);
      }

      .header-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 32px;
      }

      .site-nav {
        display: flex;
        gap: 24px;
        font-size: 15px;
      }

      .site-nav a {
        color: var(--navy-dark);
        text-decoration: none;
        font-weight: 500;
      }

      .site-nav a:hover {
        color: var(--gold-warm);
      }

      .site-footer {
        background: var(--navy-deep);
        color: var(--cream);
        padding: 56px 0 32px;
        margin-top: 96px;
      }

      .footer-inner .wordmark { color: var(--white); }

      .footer-meta {
        margin-top: 24px;
        font-size: 13px;
        color: var(--gray-mid);
      }

      .footer-meta a {
        color: var(--gold-light);
      }

      @media (max-width: 640px) {
        .header-inner { flex-direction: column; align-items: flex-start; gap: 16px; }
        .site-header { padding: 20px 0; }
        .site-footer { padding: 40px 0 24px; }
      }
    </style>
  </body>
</html>
